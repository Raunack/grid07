# copy to .env and fill in your key
# don't commit .env — it's in .gitignore for a reason

# Groq key — used across all three phases
# free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# not used by default but here if you want to swap providers
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
